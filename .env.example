# ══════════════════════════════════════════════════════════
#  AI Resume & Portfolio Builder — Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
FLASK_ENV=development          # development | production
LOG_LEVEL=INFO

# ── Gemini API ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash  # or gemini-1.5-pro

# ── Firebase ────────────────────────────────────────────────
# Option A: path to service-account JSON file
FIREBASE_CREDENTIALS_PATH=./database/firebase-service-account.json

# Option B: inline JSON string (for cloud deployments)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
